{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Research Idea Agent",
  "version": "0.1.0",
  "identifier": "com.local.research-idea-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Research Idea Agent",
        "width": 1360,
        "height": 880,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}

